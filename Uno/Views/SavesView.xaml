<UserControl x:Class="Uno.Views.SavesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">

	<Grid>
		<ScrollViewer VerticalScrollBarVisibility="Auto">
			<StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Width="1000">
				<StackPanel>
					<Button Command="{Binding VoltarCommand}" Content="Menu" 
                            HorizontalAlignment="Left" Background="White" BorderBrush="black" BorderThickness="1" 
                            Height="50" Width="150" FontSize="20" Margin="30" Style="{StaticResource RoundedButtonStyle}"/>
					<Grid>
						<ScrollViewer VerticalScrollBarVisibility="Auto">
							<StackPanel Width="550">
								<TextBlock Text="Saves Disponíveis" FontSize="25" FontWeight="Bold" HorizontalAlignment="Center"/>
								<TextBlock Text="Escolhe um jogo para retomar de onde ficaste" Margin="0,0,0,0" HorizontalAlignment="Center"/>
								<TextBlock x:Name="MensagemErro" Text="{Binding MensagemErro}" Foreground="red" Height="20" HorizontalAlignment="Center"/>
								<ListBox ItemsSource="{Binding ListaSaves}" BorderBrush="white" Height="300" BorderThickness="1">
									<ListBox.ItemTemplate>
										<DataTemplate>
											<Border Background="white" BorderBrush="black" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,5" Width="515">
												<Grid>
													<Grid.ColumnDefinitions>
														<ColumnDefinition Width="*"/>
														<ColumnDefinition Width="Auto"/>
														<ColumnDefinition Width="Auto"/>
														<ColumnDefinition Width="Auto"/>
													</Grid.ColumnDefinitions>

													<StackPanel Grid.Column="0" VerticalAlignment="Center">
														<Grid>
															<TextBlock x:Name="TxtNome" Text="{Binding NomeSave}" FontWeight="Bold" FontSize="16" Foreground="Black"/>

															<TextBox x:Name="EditNome" Text="{Binding NomeSave, UpdateSourceTrigger=PropertyChanged}" Visibility="Collapsed" FontSize="16" FontWeight="Bold">
																<TextBox.InputBindings>
																	<KeyBinding Key="Return" 
                                                                                Command="{Binding DataContext.RenomearSaveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                                                CommandParameter="{Binding}"/>
																</TextBox.InputBindings>
															</TextBox>
														</Grid>
														<TextBlock Text="Ficheiro XML" Foreground="Gray" FontSize="12"/>
													</StackPanel>

													<Button Grid.Column="1" Command="{Binding DataContext.CarregarSaveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                            CommandParameter="{Binding}" Content="Jogar" Background="red" Foreground="White" Width="80" 
                                                            Height="40" Margin="0,0,5,0" 
                                                            HorizontalAlignment="Right" Style="{StaticResource RoundedButtonStyle}"/>

													<Button Grid.Column="2" Command="{Binding DataContext.EditarSaveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                            CommandParameter="{Binding}" Content="✏️" Background="white" Foreground="Black" Width="40" Height="40" Margin="0,0,5,0" 
                                                            Style="{StaticResource RoundedButtonStyle}"/>

													<Button Grid.Column="3" Command="{Binding DataContext.ApagarSaveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                            CommandParameter="{Binding}" Content="🗑" Background="white" Foreground="Black" Width="40" Height="40" 
                                                            Style="{StaticResource RoundedButtonStyle}"/>
												</Grid>
											</Border>

											<DataTemplate.Triggers>
												<DataTrigger Binding="{Binding IsEditing}" Value="True">
													<Setter TargetName="TxtNome" Property="Visibility" Value="Collapsed"/>
													<Setter TargetName="EditNome" Property="Visibility" Value="Visible"/>
												</DataTrigger>
											</DataTemplate.Triggers>

										</DataTemplate>
									</ListBox.ItemTemplate>
								</ListBox>
							</StackPanel>
						</ScrollViewer>
					</Grid>
				</StackPanel>
			</StackPanel>
		</ScrollViewer>
	</Grid>
</UserControl>