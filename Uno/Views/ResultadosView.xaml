<UserControl x:Class="UnoDesktopGame.Views.ResultadosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F5F5">
    <Grid Margin="20">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="400" Background="White">
            <Border CornerRadius="10" Padding="20">
                <StackPanel>
					<Border Background="#FFF9E6" CornerRadius="5" Padding="10,5" Margin="0,0,0,10" HorizontalAlignment="Center">
						<TextBlock Text="Fim de jogo" Foreground="#E9C46A" FontWeight="Bold"/>
					</Border>
                    <TextBlock Text="{Binding Vencedor.Nome, StringFormat='{}{0} venceu!'}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                    <TextBlock Text="Partida concluída" Foreground="Gray" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                    <TextBlock Text="Classificação" FontWeight="SemiBold" Margin="0,10,0,10"/>

                    <ItemsControl ItemsSource="{Binding Classificacao}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#F9F9F9" CornerRadius="8" Padding="15,10" Margin="0,5">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Ellipse Grid.Column="0" Width="30" Height="30" Fill="#A8DADC" Margin="0,0,10,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Nome}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="2" Text="{Binding DataContext.JogoFinalizado.GetPontuacao, StringFormat='{}{0} pts'}" VerticalAlignment="Center" FontWeight="Bold"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                        <Button Content="Próxima ronda" Command="{Binding ProximaRondaCommand}" Background="#E63946" Foreground="White" Width="200" Height="45" Margin="0,0,10,0" Style="{StaticResource RoundedButtonStyle}"/>
                        <Button Content="Sair" Command="{Binding VoltarLobbyCommand}" Background="White" BorderBrush="#DDDDDD" BorderThickness="1" Width="80" Height="45" Style="{StaticResource RoundedButtonStyle}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>