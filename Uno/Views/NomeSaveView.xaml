<Window x:Class="Uno.Views.NomeSaveView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Suspender Partida" Height="250" Width="350" WindowStartupLocation="CenterOwner" WindowStyle="ToolWindow">

    <StackPanel Margin="20,-10,20,20" VerticalAlignment="Center">
        <TextBlock Text="Guardar Jogo" FontSize="25" FontWeight="Bold" HorizontalAlignment="Center"/>
        <TextBlock Text="Dá um nome a esta gravação:" HorizontalAlignment="Center"/>

        <TextBox x:Name="TxtNomeSave" Padding="10" Margin="0,10,0,0" BorderBrush="Black" BorderThickness="1" TextChanged="TxtNomeSave_TextChanged"/>

        <TextBlock x:Name="MensagemErro" Text="" Foreground="red" FontSize="12" Margin="10" TextWrapping="Wrap" Height="30" VerticalAlignment="Top"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Cancelar" Click="Cancelar_Click" Background="White" Foreground="black" BorderBrush="black" BorderThickness="1" Height="45" Margin="0,0,5,0" Style="{StaticResource RoundedButtonStyle}"/>
            <Button Grid.Column="1" Content="Guardar" Click="Guardar_Click" Background="red" Foreground="White" BorderBrush="black" BorderThickness="1" Height="45" Margin="5,0,0,0" Style="{StaticResource RoundedButtonStyle}"/>
        </Grid>
    </StackPanel>
</Window>