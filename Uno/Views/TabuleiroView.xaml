<UserControl x:Class="Uno.Views.TabuleiroView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="white">
    <Grid Margin="20">
        <Grid.Resources>
            <Style x:Key="EstiloCartaMagica" TargetType="Button">
                <Setter Property="Background" Value="{Binding Cor, Converter={StaticResource StringToColorConverter}}"/>
                <Setter Property="Width" Value="70"/>
                <Setter Property="Height" Value="100"/>
                <Setter Property="Margin" Value="5"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="MolduraCarta" 
                                    Background="{TemplateBinding Background}" 
                                    CornerRadius="8" 
                                    BorderBrush="Transparent" 
                                    BorderThickness="3">
                                <TextBlock Text="{Binding Simbolo}" 
                                           Foreground="White" 
                                           FontSize="24" 
                                           FontWeight="Bold" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsEnabled" Value="True">
                                    <Setter TargetName="MolduraCarta" Property="BorderBrush" Value="yellow"/>
                                    <Setter TargetName="MolduraCarta" Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect Color="yellow" BlurRadius="15" ShadowDepth="0" Opacity="1"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="MolduraCarta" Property="Opacity" Value="0.4"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ItemsControl ItemsSource="{Binding JogoAtual.Jogadores}" Grid.Row="0" HorizontalAlignment="Center">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Visibility="{Binding IsBot, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="20,0">
                        <Ellipse Width="50" Height="50" Fill="#A8DADC" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Nome}" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        <TextBlock Text="{Binding Cartas.Count, StringFormat='{}{0} cartas'}" HorizontalAlignment="Center" Foreground="black"/>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border Background="white" CornerRadius="15" Padding="10,5" HorizontalAlignment="Right" VerticalAlignment="Top" Grid.Row="0">
            <TextBlock Text="{Binding MensagemTurno}" Foreground="black" FontWeight="Bold" FontSize="14"/>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,20">
            <Button Command="{Binding ComprarCartaCommand}" Background="White" Width="80" Height="120" Margin="10">
                <StackPanel>
                    <Border Background="red" Width="60" Height="90" CornerRadius="5"/>
                    <TextBlock Text="Baralho" FontSize="10" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
            </Button>

            <Border Background="{Binding CartaTopo.Cor, Converter={StaticResource StringToColorConverter}}" Width="80" Height="120" CornerRadius="5" Margin="10">
                <TextBlock Text="{Binding CartaTopo.Simbolo}" Foreground="White" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="2">
            <TextBlock Text="{Binding MaoHumano.Count, StringFormat='A tua mão ({0} cartas)'}" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ItemsControl ItemsSource="{Binding MaoHumano}" Grid.Column="0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.JogarCartaCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                    CommandParameter="{Binding}" 
                                    Style="{StaticResource EstiloCartaMagica}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="20,0,0,0">
                    <Button Content="Gritar UNO!" Command="{Binding GritarUnoCommand}" Background="red" Foreground="White" Width="100" Height="40" Margin="0,0,0,10" Style="{StaticResource RoundedButtonStyle}"/>
                    <Button Content="Suspender" Command="{Binding SuspenderPartidaCommand}" Background="black" Foreground="White" Width="100" Height="40" Style="{StaticResource RoundedButtonStyle}"/>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>