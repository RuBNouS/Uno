<UserControl x:Class="UnoDesktopGame.Views.TabuleiroView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FAFAFA">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ItemsControl ItemsSource="{Binding JogoAtual.Jogadores}" Grid.Row="0" HorizontalAlignment="Center">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
					<StackPanel Visibility="{Binding IsBot, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="20,0">
                        <Ellipse Width="50" Height="50" Fill="#A8DADC" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Nome}" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        <TextBlock Text="{Binding Cartas.Count, StringFormat='{}{0} cartas'}" HorizontalAlignment="Center" Foreground="Gray"/>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border Background="#E9F5E9" CornerRadius="15" Padding="10,5" HorizontalAlignment="Right" VerticalAlignment="Top" Grid.Row="0">
            <TextBlock Text="A tua vez" Foreground="#2A9D8F" Visibility="{Binding IsHumanTurn, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,20">
            <Button Command="{Binding ComprarCartaCommand}" Background="White" Width="80" Height="120" Margin="10">
                <StackPanel>
                    <Border Background="#E63946" Width="60" Height="90" CornerRadius="5"/>
                    <TextBlock Text="Baralho" FontSize="10" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
            </Button>

            <Border Background="{Binding CartaTopo.Cor, Converter={StaticResource StringToColorConverter}}" Width="80" Height="120" CornerRadius="5" Margin="10">
                <TextBlock Text="{Binding CartaTopo.Simbolo}" Foreground="White" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="2">
            <TextBlock Text="A tua mão" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ItemsControl ItemsSource="{Binding MaoHumano}" Grid.Column="0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.JogarCartaCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                    CommandParameter="{Binding}" 
                                    Background="{Binding Cor, Converter={StaticResource StringToColorConverter}}" 
                                    Width="70" Height="100" Margin="5">
                                <TextBlock Text="{Binding Simbolo}" Foreground="White" FontSize="24" FontWeight="Bold"/>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="20,0,0,0">
                    <Button Content="Gritar UNO!" Command="{Binding GritarUnoCommand}" Background="#E63946" Foreground="White" Width="100" Height="40" Margin="0,0,0,10" Style="{StaticResource RoundedButtonStyle}"/>
                    <Button Content="Suspender" Command="{Binding SuspenderPartidaCommand}" Background="#457B9D" Foreground="White" Width="100" Height="40" Style="{StaticResource RoundedButtonStyle}"/>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>