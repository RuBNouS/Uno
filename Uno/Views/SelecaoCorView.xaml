<Window x:Class="Uno.Views.SelecaoCorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Escolhe uma cor" Height="250" Width="350" WindowStartupLocation="CenterOwner" WindowStyle="ToolWindow">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"/>
                            <Border x:Name="HoverLayer" Background="White" Opacity="0"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HoverLayer" Property="Opacity" Value="0.2"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <StackPanel HorizontalAlignment="Center" Margin="0,20,0,20">
        <TextBlock Text="Escolhe uma cor" FontSize="25" FontWeight="Bold" HorizontalAlignment="Center"/>
        <TextBlock Text="Seleciona a cor para continuar o jogo" HorizontalAlignment="Center"/>

        <UniformGrid Rows="2" Columns="2">
            <Button Background="#E63946" Content="Vermelho" Click="BotaoCor_Click"/>
            <Button Background="#457B9D" Content="Azul" Click="BotaoCor_Click"/>
            <Button Background="#2A9D8F" Content="Verde" Click="BotaoCor_Click"/>
            <Button Background="#E9C46A" Content="Amarelo" Click="BotaoCor_Click"/>
        </UniformGrid>
    </StackPanel>
</Window>