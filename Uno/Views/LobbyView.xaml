<UserControl x:Class="UnoDesktopGame.Views.LobbyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F5F5">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="400">
            <Border Background="#E63946" CornerRadius="10" Width="100" Height="60" Margin="0,0,0,20">
                <TextBlock Text="UNO" Foreground="White" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <TextBlock Text="Bem-vindo de volta" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
            <TextBlock Text="Inicia um novo jogo ou entra numa sala existente" Foreground="Gray" HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                <TextBlock Text="Número de Bots (1-3): " VerticalAlignment="Center"/>
                <ComboBox SelectedItem="{Binding NumeroBotsSelecionado}" Width="50" Margin="10,0,0,0">
                    <ComboBoxItem Content="1"/>
                    <ComboBoxItem Content="2"/>
                    <ComboBoxItem Content="3"/>
                </ComboBox>
            </StackPanel>

            <Button Content="Criar novo jogo" Command="{Binding CriarJogoCommand}" Background="#E63946" Foreground="White" Height="45" Margin="0,5" Style="{StaticResource RoundedButtonStyle}"/>
            <Button Content="Retomar Partida" Command="{Binding RetomarPartidaCommand}" Background="White" BorderBrush="#DDDDDD" BorderThickness="1" Height="45" Margin="0,5" Style="{StaticResource RoundedButtonStyle}"/>
            <Button Content="Ver regras do UNO" Command="{Binding VerRegrasCommand}" Background="White" BorderBrush="#DDDDDD" BorderThickness="1" Height="45" Margin="0,5" Style="{StaticResource RoundedButtonStyle}"/>
            <Button Content="Consultar Estatísticas" Command="{Binding VerEstatisticasCommand}" Background="White" BorderBrush="#DDDDDD" BorderThickness="1" Height="45" Margin="0,5" Style="{StaticResource RoundedButtonStyle}"/>
        </StackPanel>
    </Grid>
</UserControl>